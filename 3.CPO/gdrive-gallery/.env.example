# Flask
SECRET_KEY=your-random-secret-key

# Clerk（https://dashboard.clerk.com で取得）
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
CLERK_DOMAIN=your-app.clerk.accounts.dev

# Google Drive（対象の親フォルダID）
# Google DriveでフォルダURLの末尾の文字列: https://drive.google.com/drive/folders/<ここ>
GDRIVE_PARENT_FOLDER_ID=your-google-drive-folder-id

# ※ service_account.json は Google Cloud Console で作成したサービスアカウントのJSONキー
# ※ .gitignore に含まれているため Git にはコミットされません
